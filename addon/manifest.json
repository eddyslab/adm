{
  "manifest_version": 2,
  "name": "SwiftGet Download Manager",
  "version": "1.1.0",
  "description": "링크를 우클릭하여 SwiftGet으로 다운로드",

  "permissions": [
    "contextMenus",
    "cookies",
    "nativeMessaging",
    "tabs",
    "notifications"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "browser_action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "SwiftGet Download Manager",
    "default_popup": "popup.html"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "swiftget@downloader.app",
      "strict_min_version": "91.0"
    }
  }
}